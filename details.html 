<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vegetable Details - Exotic Veggies</title>
    <link rel="stylesheet" href="../css/main.css">
    <link rel="stylesheet" href="../css/details.css">
</head>
<body>
    <header>
        <h1>Exotic VegStore</h1>
        <nav>
            <div id="google_translate_element"></div>
            <a href="index.html" style="color: white; text-decoration: none; font-weight: bold; margin-right: 20px;">&larr; Back to Home</a>
        </nav>
    </header>
    
    <main class="details-container">
        <div id="loadingMessage">Loading details...</div>
        
        <!-- The details card will be injected here by JavaScript -->
        <div id="detailsCard" class="details-card hidden">
            <div class="details-image">
                <img id="vegImage" src="" alt="Vegetable">
            </div>
            <div class="details-info">
                <h2 id="vegName"></h2>
                <p class="price" id="vegPrice"></p>
                
                <ul class="spec-list">
                    <li><strong>Season:</strong> <span id="vegSeason"></span></li>
                    <li><strong>Country of Origin:</strong> <span id="vegCountry"></span></li>
                    <li><strong>Growth Duration:</strong> <span id="vegDuration"></span></li>
                </ul>

                <div class="action-buttons">
                    <button id="buyNowBtn" class="btn-primary">Buy Now</button>
                    <button id="fertilizerBtn" class="btn-secondary">View Fertilizer Details</button>
                </div>
            </div>
        </div>
    </main>

    <script src="../js/details.js"></script>


    <script src="../js/translator.js"></script>
    <script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

</body>
</html>
